# OpenClaw App Router — Caddyfile
#
# Caddy listens on 127.0.0.1:8080 and routes path prefixes to local PM2 apps.
# Tailscale Serve fronts this with HTTPS on the tailnet.
#
# Conventions:
#   - port 3000 = auth-service
#   - port 8080 = this Caddy
#   - apps start at port 3001 and increment
#
# After editing: `caddy reload --config <this-file> --adapter caddyfile`

:8080 {

    # Auth service endpoints (login form, verify, logout).
    handle /auth/* {
        reverse_proxy 127.0.0.1:3000
    }

    # Cheap liveness probe; useful for `curl <host>:4242/health`.
    handle /health {
        respond "ok" 200
    }

    # ── Open app: no password, just a path → port mapping. ────────────────
    handle /my-open-app/* {
        uri strip_prefix /my-open-app
        reverse_proxy 127.0.0.1:3001
    }

    # ── Password-protected app: forward_auth runs first, redirects to login
    #    on 401, then strips the prefix and proxies through. ──────────────
    handle /my-private-app/* {
        forward_auth 127.0.0.1:3000 {
            uri /auth/verify?app=my-private-app
            copy_headers Cookie
            @unauthorized status 401
            handle_response @unauthorized {
                redir * /auth/login?app=my-private-app&next={http.request.uri} 302
            }
        }
        uri strip_prefix /my-private-app
        reverse_proxy 127.0.0.1:3002
    }

    # ── Catch-all app index. Anything not matched above lands here.
    #    Rooted at router/public so the rendered Caddyfile, restore
    #    scripts, and logs stay out of the public web root. ─────────────
    handle {
        root * <OPENCLAW_APPS_DIR>/router/public
        try_files {path} /index.html
        file_server
    }
}
