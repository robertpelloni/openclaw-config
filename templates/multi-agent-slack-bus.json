{
  "_comment": "Multi-Agent Communication Template — Use this config on each OpenClaw gateway when coordinating with other agents across separate instances",
  "_version": "2026-03-21",
  "agents": {
    "defaults": {
      "subagents": {
        "model": null,
        "thinking": null,
        "archiveAfterMinutes": 60,
        "maxSpawnDepth": 1,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 8,
        "runTimeoutSeconds": 0
      }
    },
    "list": [
      {
        "id": "main",
        "displayName": "Agent Name (e.g., alpha, bravo, charlie)",
        "groupChat": {
          "mentionPatterns": ["\\b{name}\\b"]
        }
      }
    ]
  },
  "channels": {
    "slack": {
      "enabled": true,
      "credentials": {
        "botTokenEnvVar": "SLACK_BOT_TOKEN",
        "signingSecretEnvVar": "SLACK_SIGNING_SECRET"
      },
      "channels": {
        "<SLACK_CHANNEL_ID>": {
          "_comment": "Replace with your actual Slack channel ID",
          "requireMention": true,
          "allowBots": true,
          "aliases": ["multi-agent-bus"],
          "deliveryMode": "message"
        }
      }
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "_comment": "Enable cross-agent tool coordination"
    },
    "sessions": {
      "visibility": "all",
      "_comment": "All agents can see each other's session keys for orchestration"
    },
    "loopDetection": {
      "enabled": true,
      "genericRepeat": true,
      "pingPong": true,
      "_comment": "Prevent infinite loops between agents"
    }
  },
  "session": {
    "mainKey": "main",
    "dmScope": "main",
    "reset": {
      "mode": "daily",
      "atHour": 4
    },
    "agentToAgent": {
      "maxPingPongTurns": 5,
      "_comment": "Max 5 back-and-forths before loop breaker stops"
    },
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "30d",
      "maxEntries": 500,
      "rotateBytes": "10mb"
    }
  },
  "logging": {
    "level": "info",
    "_mention_pattern": "Set to 'debug' temporarily to troubleshoot mention patterns",
    "_loop_detection": "Set to 'debug' to see loop detection logs"
  }
}
