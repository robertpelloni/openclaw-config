[Unit]
Description=OpenClaw Health Check
After=network-online.target
Wants=network-online.target

# Activated by openclaw-health-check.timer — no [Install] section needed.
# To run manually: systemctl --user start openclaw-health-check.service

[Service]
Type=oneshot
ExecStart=/bin/bash -c '\
  export PATH="$HOME/.local/bin:$HOME/.npm-global/bin:/usr/local/bin:/usr/bin:/bin"; \
  CONFIG_REPO="$HOME/src/openclaw-config"; \
  LOG="$HOME/.openclaw/health-check-cron.log"; \
  PROMPT_FILE="$CONFIG_REPO/devops/health-check.md"; \
  if [ ! -f "$PROMPT_FILE" ]; then \
    echo "$(date -u +%%Y-%%m-%%dT%%H:%%M:%%SZ) [$(hostname -s)] ERROR: health-check.md not found at $PROMPT_FILE" >> "$LOG"; \
    exit 1; \
  fi; \
  cd "$CONFIG_REPO" || exit 1; \
  echo "$(date -u +%%Y-%%m-%%dT%%H:%%M:%%SZ) [$(hostname -s)] health check starting" >> "$LOG"; \
  CLAUDE_BIN=$(command -v claude || echo "$HOME/.npm-global/bin/claude"); \
  CLAUDE_EXIT=0; \
  "$CLAUDE_BIN" --print --dangerously-skip-permissions --max-turns 25 \
    -p "$(cat "$PROMPT_FILE")" >> "$LOG" 2>&1 || CLAUDE_EXIT=$?; \
  echo "$(date -u +%%Y-%%m-%%dT%%H:%%M:%%SZ) [$(hostname -s)] health check done (exit $CLAUDE_EXIT)" >> "$LOG"; \
  exit $CLAUDE_EXIT'
StandardError=append:%h/.openclaw/logs/health-check-errors.log
